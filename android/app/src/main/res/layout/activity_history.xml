<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_app_light">

    <!-- CABECERA (igual que en transfer y perfil) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="24dp"
        android:paddingBottom="8dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:background="@color/bg_app_light">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_arrow_back"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="@color/teal_primary"
                android:layout_alignParentStart="true"
                android:contentDescription="Atrás" />

            <ImageView
                android:id="@+id/ivLogo"
                android:layout_width="100dp"
                android:layout_height="32dp"
                android:src="@drawable/logo_verde"
                android:layout_centerInParent="true"
                android:contentDescription="Logo" />
        </RelativeLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Historial"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/primary_dark"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tus movimientos recientes"
            android:textSize="14sp"
            android:textColor="@color/text_hint_muted" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingBottom="32dp">

            <!-- TARJETA DE ESTADÍSTICAS / CATEGORÍAS -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_rounded"
                android:padding="20dp"
                android:layout_marginBottom="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="RESUMEN POR CATEGORÍAS"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/teal_primary"
                    android:layout_marginBottom="16dp" />

                <!-- Fila: gráfico circular simulado + lista de categorías -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <!-- Círculo con porcentaje central (simulación) -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="16dp">

                        <androidx.cardview.widget.CardView
                            android:layout_width="100dp"
                            android:layout_height="100dp"
                            app:cardCornerRadius="50dp"
                            app:cardElevation="2dp"
                            android:elevation="2dp"
                            app:cardBackgroundColor="@color/pale_aqua_field">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:orientation="vertical"
                                android:gravity="center">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="55%"
                                    android:textSize="24sp"
                                    android:textStyle="bold"
                                    android:textColor="@color/teal_primary" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Gastos"
                                    android:textSize="12sp"
                                    android:textColor="@color/text_hint_muted" />
                            </LinearLayout>
                        </androidx.cardview.widget.CardView>
                    </LinearLayout>

                    <!-- Lista de categorías con colores -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="8dp">
                            <View
                                android:layout_width="12dp"
                                android:layout_height="12dp"
                                android:background="@color/teal_primary"
                                android:layout_marginEnd="8dp" />
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Transaction"
                                android:textSize="14sp"
                                android:textColor="@color/primary_dark" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="55%"
                                android:textSize="14sp"
                                android:textColor="@color/primary_dark"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="8dp">
                            <View
                                android:layout_width="12dp"
                                android:layout_height="12dp"
                                android:background="@color/orange_accent"
                                android:layout_marginEnd="8dp" />
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Transfer"
                                android:textSize="14sp"
                                android:textColor="@color/primary_dark" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="20%"
                                android:textSize="14sp"
                                android:textColor="@color/primary_dark"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="8dp">
                            <View
                                android:layout_width="12dp"
                                android:layout_height="12dp"
                                android:background="@color/green_accent"
                                android:layout_marginEnd="8dp" />
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Travel"
                                android:textSize="14sp"
                                android:textColor="@color/primary_dark" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="10%"
                                android:textSize="14sp"
                                android:textColor="@color/primary_dark"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="8dp">
                            <View
                                android:layout_width="12dp"
                                android:layout_height="12dp"
                                android:background="@color/yellow_accent"
                                android:layout_marginEnd="8dp" />
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Food"
                                android:textSize="14sp"
                                android:textColor="@color/primary_dark" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="8%"
                                android:textSize="14sp"
                                android:textColor="@color/primary_dark"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="8dp">
                            <View
                                android:layout_width="12dp"
                                android:layout_height="12dp"
                                android:background="@color/red_accent"
                                android:layout_marginEnd="8dp" />
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Shopping"
                                android:textSize="14sp"
                                android:textColor="@color/primary_dark" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="5%"
                                android:textSize="14sp"
                                android:textColor="@color/primary_dark"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">
                            <View
                                android:layout_width="12dp"
                                android:layout_height="12dp"
                                android:background="@color/purple_accent"
                                android:layout_marginEnd="8dp" />
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Car"
                                android:textSize="14sp"
                                android:textColor="@color/primary_dark" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="2%"
                                android:textSize="14sp"
                                android:textColor="@color/primary_dark"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- TARJETA DE TRANSACCIONES RECIENTES -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_rounded"
                android:padding="20dp"
                android:layout_marginBottom="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TRANSACCIONES RECIENTES"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/teal_primary"
                    android:layout_marginBottom="16dp" />

                <!-- Grupo: Hoy -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hoy"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary_dark"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="12dp" />

                <!-- Transacción 1 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_apple_store"
                        android:background="@drawable/bg_circle_teal_light"
                        android:padding="8dp"
                        android:contentDescription="Icono" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Apple Store"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/primary_dark" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Entretenimiento"
                            android:textSize="12sp"
                            android:textColor="@color/text_hint_muted" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="-$5.99"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/red_accent" />
                </LinearLayout>

                <!-- Transacción 2 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_spotify"
                        android:background="@drawable/bg_circle_teal_light"
                        android:padding="8dp"
                        android:contentDescription="Icono" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Spotify"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/primary_dark" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Música"
                            android:textSize="12sp"
                            android:textColor="@color/text_hint_muted" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="-$12.99"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/red_accent" />
                </LinearLayout>

                <!-- Grupo: Últimos 7 días -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Últimos 7 días"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary_dark"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="12dp" />

                <!-- Transacción 3 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_spotify"
                        android:background="@drawable/bg_circle_teal_light"
                        android:padding="8dp"
                        android:contentDescription="Icono" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Spotify"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/primary_dark" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Suscripción mensual"
                            android:textSize="12sp"
                            android:textColor="@color/text_hint_muted" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="-$12.99"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/red_accent" />
                </LinearLayout>

                <!-- Ver más (opcional) -->
                <Button
                    android:id="@+id/btnViewAll"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="Ver todas"
                    android:textSize="14sp"
                    android:background="@drawable/bg_outline_button"
                    android:textColor="@color/teal_primary"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="8dp"
                    android:paddingHorizontal="24dp" />
            </LinearLayout>

            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="gone"
                android:layout_gravity="center" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>