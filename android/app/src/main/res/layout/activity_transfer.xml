<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_app_light">

    <!-- Círculos decorativos de fondo (posiciones únicas para transferencia) -->
    <View
        android:layout_width="320dp"
        android:layout_height="320dp"
        android:layout_marginTop="-130dp"
        android:layout_marginStart="-100dp"
        android:background="@drawable/bg_circle_primary_light"
        android:alpha="0.25" />

    <View
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:layout_alignParentEnd="true"
        android:layout_marginTop="180dp"
        android:layout_marginEnd="-80dp"
        android:background="@drawable/bg_circle_secondary_light"
        android:alpha="0.3" />

    <View
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="40dp"
        android:layout_marginStart="20dp"
        android:background="@drawable/bg_circle_primary_light"
        android:alpha="0.2" />

    <View
        android:layout_width="130dp"
        android:layout_height="130dp"
        android:layout_alignParentBottom="true"
        android:layout_alignParentEnd="true"
        android:layout_marginBottom="120dp"
        android:layout_marginEnd="-40dp"
        android:background="@drawable/bg_circle_secondary_light"
        android:alpha="0.35" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- CABECERA -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="24dp"
                android:paddingBottom="8dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:background="@color/bg_app_light">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp">

                    <ImageButton
                        android:id="@+id/btnBack"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_arrow_back"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:tint="@color/primary"
                        android:layout_alignParentStart="true"
                        android:contentDescription="@string/back_description" />

                    <ImageView
                        android:id="@+id/ivLogo"
                        android:layout_width="100dp"
                        android:layout_height="32dp"
                        android:src="@drawable/logo_verde"
                        android:layout_centerInParent="true"
                        android:contentDescription="@string/logo_description" />
                </RelativeLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/transfer_title"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary_dark"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/transfer_subtitle"
                    android:textSize="14sp"
                    android:textColor="@color/text_hint_muted" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="20dp"
                android:paddingBottom="32dp">

                <!-- TARJETA RECEPTOR -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card_rounded"
                    android:padding="20dp"
                    android:layout_marginBottom="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/transfer_receiver_label"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary"
                        android:layout_marginBottom="16dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <LinearLayout
                            android:layout_width="64dp"
                            android:layout_height="64dp"
                            android:background="@drawable/bg_circle_primary_light"
                            android:gravity="center">

                            <ImageView
                                android:id="@+id/ivAvatar"
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:src="@drawable/ic_avatar_default"
                                android:contentDescription="@string/profile_avatar_description" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="16dp">

                            <TextView
                                android:id="@+id/tvReceptorName"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/transfer_receiver_name"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:textColor="@color/primary_dark" />

                            <TextView
                                android:id="@+id/tvReceptorId"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/transfer_receiver_id"
                                android:textSize="13sp"
                                android:textColor="@color/text_hint_muted" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/transfer_receiver_verified"
                                android:textSize="11sp"
                                android:textColor="@color/primary"
                                android:background="@color/pale_aqua_field"
                                android:paddingHorizontal="8dp"
                                android:paddingVertical="2dp"
                                android:layout_marginTop="4dp" />
                        </LinearLayout>

                        <ImageButton
                            android:id="@+id/btnChangeReceiver"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@drawable/ic_chevron_right"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:tint="@color/primary"
                            android:contentDescription="@string/transfer_change_receiver_description" />
                    </LinearLayout>
                </LinearLayout>

                <!-- TARJETA CUENTA ORIGEN -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card_rounded"
                    android:padding="20dp"
                    android:layout_marginBottom="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/transfer_from_label"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary"
                        android:layout_marginBottom="16dp" />

                    <LinearLayout
                        android:id="@+id/layoutAccountSelector"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@drawable/ic_account_balance"
                            android:tint="@color/primary"
                            android:background="@drawable/bg_circle_primary_light"
                            android:padding="10dp" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="16dp">

                            <TextView
                                android:id="@+id/tvAccountName"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/transfer_account_name"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:textColor="@color/primary_dark" />

                            <TextView
                                android:id="@+id/tvAccountBalance"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/transfer_account_balance"
                                android:textSize="14sp"
                                android:textColor="@color/primary"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <ImageButton
                            android:id="@+id/btnChangeAccount"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@drawable/ic_chevron_right"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:tint="@color/primary"
                            android:contentDescription="@string/transfer_change_account_description" />
                    </LinearLayout>
                </LinearLayout>

                <!-- TARJETA MONTO -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card_rounded"
                    android:padding="20dp"
                    android:gravity="center_horizontal"
                    android:layout_marginBottom="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/transfer_amount_label"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary"
                        android:layout_marginBottom="12dp" />

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_edittext_rounded"
                        android:padding="4dp"
                        android:layout_marginBottom="16dp">

                        <EditText
                            android:id="@+id/etAmount"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="numberDecimal"
                            android:textSize="32sp"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:padding="16dp"
                            android:textColor="@color/primary_dark"
                            android:background="@android:color/transparent"
                            android:hint="@string/transfer_amount_hint"
                            android:textColorHint="@color/text_hint_muted" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:layout_marginBottom="8dp">

                        <Button
                            android:id="@+id/btnAmount10"
                            android:layout_width="0dp"
                            android:layout_height="40dp"
                            android:layout_weight="1"
                            android:text="$10"
                            android:textSize="14sp"
                            android:background="@drawable/bg_outline_button"
                            android:textColor="@color/primary"
                            android:layout_marginEnd="8dp" />

                        <Button
                            android:id="@+id/btnAmount20"
                            android:layout_width="0dp"
                            android:layout_height="40dp"
                            android:layout_weight="1"
                            android:text="$20"
                            android:textSize="14sp"
                            android:background="@drawable/bg_outline_button"
                            android:textColor="@color/primary"
                            android:layout_marginEnd="8dp" />

                        <Button
                            android:id="@+id/btnAmount50"
                            android:layout_width="0dp"
                            android:layout_height="40dp"
                            android:layout_weight="1"
                            android:text="$50"
                            android:textSize="14sp"
                            android:background="@drawable/bg_outline_button"
                            android:textColor="@color/primary"
                            android:layout_marginEnd="8dp" />

                        <Button
                            android:id="@+id/btnAmount100"
                            android:layout_width="0dp"
                            android:layout_height="40dp"
                            android:layout_weight="1"
                            android:text="$100"
                            android:textSize="14sp"
                            android:background="@drawable/bg_outline_button"
                            android:textColor="@color/primary" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="8dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/transfer_fee_text"
                            android:textSize="12sp"
                            android:textColor="@color/text_hint_muted" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/transfer_speed_text"
                            android:textSize="12sp"
                            android:textColor="@color/primary"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <!-- TARJETA CUENTA DESTINO -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card_rounded"
                    android:padding="20dp"
                    android:layout_marginBottom="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/transfer_destination_label"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary"
                        android:layout_marginBottom="12dp" />

                    <EditText
                        android:id="@+id/etTargetAccount"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/transfer_destination_hint"
                        android:inputType="text"
                        android:padding="16dp"
                        android:background="@drawable/bg_edittext_rounded"
                        android:textColor="@color/primary_dark"
                        android:textSize="16sp"
                        android:maxLength="10" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/transfer_destination_format"
                        android:textSize="11sp"
                        android:textColor="@color/text_hint_muted"
                        android:layout_marginTop="4dp" />
                </LinearLayout>

                <!-- TARJETA CONCEPTO -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card_rounded"
                    android:padding="20dp"
                    android:layout_marginBottom="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/transfer_concept_label"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary"
                        android:layout_marginBottom="12dp" />

                    <EditText
                        android:id="@+id/etConcept"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/transfer_concept_hint"
                        android:inputType="text"
                        android:padding="16dp"
                        android:background="@drawable/bg_edittext_rounded"
                        android:textColor="@color/primary_dark"
                        android:textSize="16sp" />
                </LinearLayout>

                <!-- BOTÓN CONTINUAR -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSubmitTransfer"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="@string/transfer_continue_button"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:backgroundTint="@color/primary"
                    app:cornerRadius="28dp"
                    android:layout_marginBottom="16dp" />

                <ProgressBar
                    android:id="@+id/progressBar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:visibility="gone" />

            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</RelativeLayout>