<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_app_light">

    <!-- Cabecera simple (opcional, puede ir sin logo) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:background="@color/white"
        android:elevation="2dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Términos y Condiciones"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/primary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Última actualización: 1 de abril de 2025"
            android:textSize="12sp"
            android:textColor="@color/text_hint_muted" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="1. Aceptación de los términos"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Al acceder y utilizar la aplicación GS04 Bank App, usted acepta cumplir con estos términos y condiciones. Si no está de acuerdo, no utilice la aplicación."
                android:textSize="14sp"
                android:textColor="@color/primary_dark"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="2. Uso de la aplicación"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Usted se compromete a usar la aplicación solo para fines legales y de acuerdo con todas las leyes aplicables. No debe intentar acceder a áreas restringidas ni interferir con el funcionamiento de la aplicación."
                android:textSize="14sp"
                android:textColor="@color/primary_dark"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="3. Privacidad y datos"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Sus datos personales serán tratados conforme a nuestra Política de Privacidad. Al usar la aplicación, usted consiente dicha recolección y uso."
                android:textSize="14sp"
                android:textColor="@color/primary_dark"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="4. Responsabilidad"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="La aplicación se proporciona 'tal cual'. No garantizamos que esté libre de errores o interrupciones. No seremos responsables por daños indirectos derivados del uso de la aplicación."
                android:textSize="14sp"
                android:textColor="@color/primary_dark"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="5. Cambios a los términos"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Podemos actualizar estos términos en cualquier momento. Le notificaremos sobre cambios importantes mediante la aplicación o por correo electrónico."
                android:textSize="14sp"
                android:textColor="@color/primary_dark"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="6. Contacto"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Si tienes preguntas sobre estos términos, contáctanos en soporte@gs04bank.com."
                android:textSize="14sp"
                android:textColor="@color/primary_dark" />
        </LinearLayout>
    </ScrollView>

    <!-- Botones de acción -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="20dp"
        android:gravity="center_horizontal"
        android:background="@color/white"
        android:elevation="4dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDecline"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="Rechazar"
            android:textColor="@color/primary"
            android:backgroundTint="@android:color/transparent"
            app:strokeColor="@color/primary"
            app:strokeWidth="1dp"
            app:cornerRadius="24dp"
            android:layout_marginEnd="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAccept"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="Aceptar"
            android:textColor="#333333"
            android:backgroundTint="@color/secondary"
            app:cornerRadius="24dp" />
    </LinearLayout>
</LinearLayout>