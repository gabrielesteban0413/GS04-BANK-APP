<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_app_light">

    <!-- CABECERA (igual que en transfer) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="24dp"
        android:paddingBottom="8dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:background="@color/bg_app_light">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_arrow_back"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="@color/teal_primary"
                android:layout_alignParentStart="true"
                android:contentDescription="Atrás" />

            <ImageView
                android:id="@+id/ivLogo"
                android:layout_width="100dp"
                android:layout_height="32dp"
                android:src="@drawable/logo_verde"
                android:layout_centerInParent="true"
                android:contentDescription="Logo" />
        </RelativeLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Editar perfil"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/primary_dark"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Actualiza tu información personal"
            android:textSize="14sp"
            android:textColor="@color/text_hint_muted" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingBottom="32dp">

            <!-- TARJETA DE PERFIL (avatar + nombre + rol) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_rounded"
                android:padding="20dp"
                android:layout_marginBottom="20dp"
                android:gravity="center_horizontal">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center">

                    <!-- Avatar con botón de cambio (circular) -->
                    <RelativeLayout
                        android:layout_width="100dp"
                        android:layout_height="100dp"
                        android:layout_marginBottom="12dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/bg_circle_teal_light"
                            android:gravity="center">

                            <ImageView
                                android:id="@+id/ivProfileAvatar"
                                android:layout_width="80dp"
                                android:layout_height="80dp"
                                android:src="@drawable/ic_avatar_default"
                                android:contentDescription="Avatar" />
                        </LinearLayout>

                        <ImageButton
                            android:id="@+id/btnChangePhoto"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/ic_camera"
                            android:background="@drawable/bg_circle_white"
                            android:tint="@color/teal_primary"
                            android:layout_alignParentEnd="true"
                            android:layout_alignParentBottom="true"
                            android:contentDescription="Cambiar foto" />
                    </RelativeLayout>

                    <TextView
                        android:id="@+id/tvProfileName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tanya Myroniuk"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary_dark" />

                    <TextView
                        android:id="@+id/tvProfileRole"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Senior Designer"
                        android:textSize="14sp"
                        android:textColor="@color/text_hint_muted"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- TARJETA DE CAMPOS EDITABLES -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_rounded"
                android:padding="20dp"
                android:layout_marginBottom="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="INFORMACIÓN PERSONAL"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/teal_primary"
                    android:layout_marginBottom="16dp" />

                <!-- Nombre completo -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nombre completo"
                    android:textSize="13sp"
                    android:textColor="@color/primary_dark"
                    android:layout_marginBottom="4dp" />

                <EditText
                    android:id="@+id/etFullName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Tu nombre completo"
                    android:inputType="textPersonName"
                    android:padding="16dp"
                    android:background="@drawable/bg_edittext_rounded"
                    android:textColor="@color/primary_dark"
                    android:textSize="16sp"
                    android:layout_marginBottom="16dp" />

                <!-- Correo electrónico -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Correo electrónico"
                    android:textSize="13sp"
                    android:textColor="@color/primary_dark"
                    android:layout_marginBottom="4dp" />

                <EditText
                    android:id="@+id/etEmail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="tucorreo@ejemplo.com"
                    android:inputType="textEmailAddress"
                    android:padding="16dp"
                    android:background="@drawable/bg_edittext_rounded"
                    android:textColor="@color/primary_dark"
                    android:textSize="16sp"
                    android:layout_marginBottom="16dp" />

                <!-- Teléfono -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Teléfono"
                    android:textSize="13sp"
                    android:textColor="@color/primary_dark"
                    android:layout_marginBottom="4dp" />

                <EditText
                    android:id="@+id/etPhone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="+1234567890"
                    android:inputType="phone"
                    android:padding="16dp"
                    android:background="@drawable/bg_edittext_rounded"
                    android:textColor="@color/primary_dark"
                    android:textSize="16sp"
                    android:layout_marginBottom="16dp" />

                <!-- Fecha de nacimiento -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Fecha de nacimiento"
                    android:textSize="13sp"
                    android:textColor="@color/primary_dark"
                    android:layout_marginBottom="4dp" />

                <EditText
                    android:id="@+id/etBirthDate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="DD/MM/AAAA"
                    android:inputType="date"
                    android:padding="16dp"
                    android:background="@drawable/bg_edittext_rounded"
                    android:textColor="@color/primary_dark"
                    android:textSize="16sp" />
            </LinearLayout>

            <!-- TARJETA DE INFORMACIÓN ADICIONAL (solo lectura) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_rounded"
                android:padding="20dp"
                android:layout_marginBottom="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="OTROS DATOS"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/teal_primary"
                    android:layout_marginBottom="12dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Miembro desde:"
                        android:textSize="14sp"
                        android:textColor="@color/text_hint_muted" />

                    <TextView
                        android:id="@+id/tvJoinedDate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="28 enero 2021"
                        android:textSize="14sp"
                        android:textColor="@color/primary_dark"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <!-- BOTÓN GUARDAR CAMBIOS -->
            <Button
                android:id="@+id/btnSaveProfile"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Guardar cambios"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:background="@drawable/bg_button_rounded"
                android:layout_marginBottom="16dp" />

            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="gone"
                android:layout_gravity="center" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>